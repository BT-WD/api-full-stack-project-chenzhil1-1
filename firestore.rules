rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      // A signed-in user can create and manage only their own profile.
      allow create: if isOwner(uid)
        && request.resource.data.uid == request.auth.uid;

      allow read, update, delete: if isOwner(uid);

      // Likes and history are private to each signed-in owner.
      match /likes/{likeId} {
        allow read, write: if isOwner(uid);
      }

      match /history/{historyId} {
        allow read, write: if isOwner(uid);
      }
    }

    match /usernames/{usernameKey} {
      // Needed for pre-login username -> email lookup.
      allow get: if true;
      allow list: if false;

      // A signed-in user can claim/update only their own username document.
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.normalizedUsername == usernameKey;

      allow update, delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
